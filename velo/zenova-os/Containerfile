## ═══════════════════════════════════════════════════════════════════
##  ZENOVA OS — Gaming Without Limits
##  A clean, modern, no-bloat gaming Linux distribution
##  Based on Bazzite (Universal Blue / Fedora Atomic)
## ═══════════════════════════════════════════════════════════════════

ARG BASE_IMAGE="ghcr.io/ublue-os/bazzite-kinoite"
ARG FEDORA_MAJOR_VERSION="41"

FROM ${BASE_IMAGE}:${FEDORA_MAJOR_VERSION} AS zenova

ARG FEDORA_MAJOR_VERSION

# ── Branding & Metadata ──
LABEL org.opencontainers.image.title="Zenova OS"
LABEL org.opencontainers.image.description="A premium gaming Linux distro — clean, fast, no bloat."
LABEL org.opencontainers.image.version="1.0.0"
LABEL io.astron.variant="Kinoite"
LABEL io.astron.desktop="KDE"

# ── Repository Setup ──
COPY config/files/etc/yum.repos.d/ /etc/yum.repos.d/
RUN rpm --import https://brave-browser-rpm-release.s3.brave.com/brave-core.asc

# ── System Customization ──
# Consolidate package management into fewer layers
RUN rpm-ostree override remove firefox firefox-langpacks gnome-tour 2>/dev/null || true && \
    rpm-ostree install \
    brave-browser corectrl radeontop \
    lutris wine winetricks protontricks \
    kvantum papirus-icon-theme plasma-discover-flatpak \
    fish zsh zsh-autosuggestions zsh-syntax-highlighting starship \
    fastfetch btop fzf bat ripgrep eza fd-find tldr \
    ffmpeg gstreamer1-plugins-bad-free gstreamer1-plugins-ugly \
    google-noto-sans-fonts google-noto-sans-mono-fonts jetbrains-mono-fonts \
    wireguard-tools p7zip unrar && \
    rpm-ostree cleanup -m

# ── Copy Custom Files & Scripts ──
COPY config/files/ /
COPY config/scripts/ /tmp/scripts/

# ── Build Logic & Branding ──
RUN chmod +x /tmp/scripts/*.sh && \
    /tmp/scripts/build.sh && \
    rm -rf /tmp/scripts && \
    # Set Executable Permissions for Zenova tools
    chmod +x /usr/libexec/zenova-* && \
    # Enable First-Boot Service
    systemctl enable zenova-firstboot.service && \
    # Set OS Branding in /usr/lib/os-release
    sed -i 's/^NAME=.*/NAME="Zenova OS"/' /usr/lib/os-release && \
    sed -i 's/^PRETTY_NAME=.*/PRETTY_NAME="Zenova OS 41.0 (Ignition)"/' /usr/lib/os-release && \
    sed -i 's/^ID=.*/ID=zenova/' /usr/lib/os-release && \
    sed -i 's/^VARIANT_ID=.*/VARIANT_ID=zenova/' /usr/lib/os-release && \
    echo 'VERSION="1.0.0 (Ignition)"' >> /usr/lib/os-release && \
    # Final Cleanup
    rm -rf /var/cache/* /tmp/* && \
    ostree container commit

